{
  "name": "mcp-cli-checker",
  "version": "1.0.0",
  "description": "CLI tool that connects to an MCP server and lints its tool definitions",
  "type": "module",
  "packageManager": "pnpm@8.15.6",
  "bin": {
    "mcp-check": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "dev": "tsx src/cli.ts",
    "agents:sync": "node scripts/agents/sync-agent-shims.mjs",
    "agents:check": "node scripts/agents/sync-agent-shims.mjs --check",
    "postinstall": "node scripts/agents/sync-agent-shims.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "commander": "^12.1.0",
    "picocolors": "^1.1.1",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.12.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
